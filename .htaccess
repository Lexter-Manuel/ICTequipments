RewriteEngine On
Options -Indexes

# ── Security Headers ────────────────────────────────────────────
<IfModule mod_headers.c>
    # Prevent clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"
    # Prevent MIME-type sniffing
    Header always set X-Content-Type-Options "nosniff"
    # Enable XSS protection in older browsers
    Header always set X-XSS-Protection "1; mode=block"
    # Only send origin as referrer to external sites
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    # Restrict resource permissions
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    # Prevent caching of sensitive pages
    Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0" "expr=%{REQUEST_URI} =~ m#\.(php)$#"
    # Remove server signature
    Header always unset X-Powered-By
    Header always unset Server
</IfModule>

# ── Block sensitive file types from being downloaded ────────────
<FilesMatch "\.(sql|env|ini|log|bak|sh|git|svn)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# ── Block access to hidden files (.env, .git, .htaccess copies) ─
<FilesMatch "^\.">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# ── Disable server signature ────────────────────────────────────
ServerSignature Off

# ── Redirect public/dashboard.php to clean URL ─────────────────
# Uses THE_REQUEST to derive the base path dynamically (no hardcoding)
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteCond %{THE_REQUEST} \s(.*)/public/dashboard\.php [NC]
RewriteRule ^ %1/ [R=302,L]

# ── Block direct browser navigation to module pages ─────────────
# Modules are loaded via fetch() inside the dashboard shell.
# Direct browser navigation (Sec-Fetch-Mode: navigate) is redirected.
# Auth pages (login, logout, error pages) are exempted.
RewriteCond %{HTTP:Sec-Fetch-Mode} ^navigate$ [NC]
RewriteRule ^modules/(?!auth/) public/dashboard.php [L]

# ── Route root to dashboard ────────────────────────────────────
RewriteRule ^(index\.php)?$ public/dashboard.php [L]

# ── Serve existing files/directories as-is ──────────────────────
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# ── Fallback: everything else → 404 ────────────────────────────
RewriteRule ^ modules/auth/404.php [L]