RewriteEngine On
Options -Indexes

ErrorDocument 404 /modules/auth/404.php
ErrorDocument 403 /modules/auth/403.php

RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^public/dashboard\.php$ ./ [R=302,L]

RewriteRule ^(index\.php)?$ public/dashboard.php [L]

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^ modules/auth/404.php [L]