RewriteEngine On
RewriteBase /ictequipment/

# Disable directory listing everywhere
Options -Indexes

# Custom error pages
ErrorDocument 404 /ictequipment/modules/auth/404.php
ErrorDocument 403 /ictequipment/modules/auth/unauthorized.php

# Redirect direct hits to public/dashboard.php back to clean root URL
RewriteCond %{THE_REQUEST} \s/ictequipment/public/dashboard\.php[\s?#] [NC]
RewriteRule ^ /ictequipment/ [R=302,L]

# Rewrite clean root URL to public/dashboard.php (BEFORE file/dir check)
RewriteRule ^(index\.php)?$ public/dashboard.php [L]

# Don't rewrite other requests for actual files or directories
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Everything else that doesn't match a file → 404
RewriteRule ^ modules/auth/404.php [L]
